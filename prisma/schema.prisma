datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres@localhost:5432/ocopdb3"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isActive     Boolean  @default(true)
  userRoles    UserRole[]
  auditLogs    AuditLog[]
}

model Role {
  id       String    @id @default(uuid())
  name     String    @unique
  userRoles UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])
  @@id([userId, roleId])
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  model     String
  modelId   String?
  timestamp DateTime @default(now())
}
