datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isActive     Boolean  @default(true)
  // relations would be added later (roles, profiles, etc.)
}

model Role {
  id   String @id @default(uuid())
  name String @unique
}

model UserRole {
  userId String
  roleId String
  User   User @relation(fields: [userId], references: [id])
  Role   Role @relation(fields: [roleId], references: [id])
  @@id([userId, roleId])
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  model     String
  modelId   String?
  timestamp DateTime @default(now())
  User      User?    @relation(fields: [userId], references: [id])
}
